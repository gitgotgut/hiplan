# Copy this file to .env.local and fill in the values

# PostgreSQL — shared database with all hifamily platforms
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Shared SSO secret — MUST be identical across hifamily, hugo, hiplan, himage.
# Used to verify the short-lived handoff token from hifamily. (openssl rand -base64 32)
JWT_SECRET="your-shared-jwt-secret-here"

# NextAuth — for the LOCAL session cookie issued after SSO. (openssl rand -base64 32)
NEXTAUTH_SECRET="your-local-session-secret-here"
NEXTAUTH_URL="http://localhost:3002"

# Navigation / SSO endpoints
NEXT_PUBLIC_HIFAMILY_URL="http://localhost:3000"
NEXT_PUBLIC_HUGO_URL="http://localhost:3001"
NEXT_PUBLIC_PLANS_URL="http://localhost:3002"
NEXT_PUBLIC_PHOTO_URL="http://localhost:3003"
