# Copy this file to .env.local and fill in the values

# PostgreSQL — shared database with all hifamily platforms
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# hifamily integration — for auth token validation
HIFAMILY_URL="http://localhost:3000"
HIFAMILY_API_KEY="your-hifamily-public-key-here"

# Navigation
NEXT_PUBLIC_HIFAMILY_URL="http://localhost:3000"
NEXT_PUBLIC_HUGO_URL="http://localhost:3001"
NEXT_PUBLIC_PLANS_URL="http://localhost:3002"
NEXT_PUBLIC_PHOTO_URL="http://localhost:3003"
